<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FinanceManager.App">

	<Application.Styles>
		<FluentTheme />

		<!-- ===== ГЛОБАЛЬНЫЕ СТИЛИ ===== -->
		<Style Selector="Window">
			<Setter Property="Background" Value="#1E1E1E"/>
		</Style>

		<!-- ===== TITLE ===== -->
		<Style Selector="TextBlock">
			<Setter Property="Foreground" Value="#E0E0E0"/>
		</Style>

		<!-- ===== TEXTBOX ===== -->
		<Style Selector="TextBox">
			<Setter Property="Background" Value="#2D2D2D"/>
			<Setter Property="Foreground" Value="#E0E0E0"/>
			<Setter Property="BorderBrush" Value="#444444"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Padding" Value="10"/>
			<Setter Property="Margin" Value="0,5"/>
		</Style>
		<Style Selector="TextBox:focus-within">
			<Setter Property="BorderBrush" Value="#6B6B6B"/>
		</Style>

		<!-- ===== BUTTON ===== -->
		<Style Selector="Button">
			<Setter Property="Background" Value="#3A3A3A"/>
			<Setter Property="Foreground" Value="#E0E0E0"/>
			<Setter Property="BorderBrush" Value="#555555"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Padding" Value="12,8"/>
			<Setter Property="Margin" Value="0,5"/>
			<Setter Property="MinWidth" Value="100"/>
		</Style>
		<Style Selector="Button:pointerover">
			<Setter Property="Background" Value="#4A4A4A"/>
		</Style>
		<Style Selector="Button:pressed">
			<Setter Property="Background" Value="#2A2A2A"/>
		</Style>

		<!-- ===== COMBOBOX ===== -->
		<Style Selector="ComboBox">
			<Setter Property="Background" Value="#2D2D2D"/>
			<Setter Property="Foreground" Value="#E0E0E0"/>
			<Setter Property="BorderBrush" Value="#444444"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Padding" Value="8"/>
			<Setter Property="Margin" Value="0,5"/>
		</Style>

		<!-- ===== LISTBOX ===== -->
		<Style Selector="ListBox">
			<Setter Property="Background" Value="#252525"/>
			<Setter Property="BorderBrush" Value="#444444"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Padding" Value="5"/>
		</Style>

		<Style Selector="ListBoxItem">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="#E0E0E0"/>
			<Setter Property="Padding" Value="8,6"/>
			<Setter Property="CornerRadius" Value="4"/>
		</Style>

		<Style Selector="ListBoxItem:pointerover">
			<Setter Property="Background" Value="#3A3A3A"/>
		</Style>

		<Style Selector="ListBoxItem:selected">
			<Setter Property="Background" Value="#4A4A4A"/>
		</Style>

		<!-- ===== COMBOBOX ITEM ===== -->
		<Style Selector="ComboBoxItem:pointerover">
			<Setter Property="Background" Value="#3A3A3A"/>
		</Style>

		<Style Selector="ComboBoxItem:selected">
			<Setter Property="Background" Value="#4A4A4A"/>
		</Style>

		<!-- ===== RADIOBUTTON ===== -->
		<Style Selector="RadioButton">
			<Setter Property="Foreground" Value="#E0E0E0"/>
			<Setter Property="Margin" Value="0,5"/>
		</Style>

		<!-- ===== SCROLLBAR ===== -->
		<Style Selector="ScrollBar">
			<Setter Property="Background" Value="#2D2D2D"/>
		</Style>

		<Style Selector="Thumb">
			<Setter Property="Background" Value="#555555"/>
			<Setter Property="CornerRadius" Value="4"/>
		</Style>

		<Style Selector="Thumb:pointerover">
			<Setter Property="Background" Value="#777777"/>
		</Style>

		<!-- ===== BORDER ===== -->
		<Style Selector="Border">
			<Setter Property="Background" Value="#2D2D2D"/>
			<Setter Property="CornerRadius" Value="6"/>
		</Style>

		<!-- ===== GRID LINES (убрать) ===== -->
		<Style Selector="Grid">
			<Setter Property="ShowGridLines" Value="False"/>
		</Style>
	</Application.Styles>
</Application>